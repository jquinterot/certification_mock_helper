{
  "name": "aws-ml-exam",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "PLAYWRIGHT_FORCE_ASYNC_LOADER=1 playwright test",
    "test:e2e:ui": "PLAYWRIGHT_FORCE_ASYNC_LOADER=1 playwright test --ui",
    "test:e2e:chromium": "PLAYWRIGHT_FORCE_ASYNC_LOADER=1 playwright test --project=chromium",
    "test:e2e:firefox": "PLAYWRIGHT_FORCE_ASYNC_LOADER=1 playwright test --project=firefox",
    "test:e2e:webkit": "PLAYWRIGHT_FORCE_ASYNC_LOADER=1 playwright test --project=webkit",
    "test:e2e:headed": "PLAYWRIGHT_FORCE_ASYNC_LOADER=1 playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "vitest related --run"
    ],
    "*.{js,mjs,cjs,json,md,yml,yaml}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
